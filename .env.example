# Production Quilt API endpoint
QUILT_API_URL=https://backend.quilt.sh

# Required auth for production API
# Set one of these:
QUILT_API_KEY=
# QUILT_TOKEN=

# Optional override for oci=true image target
# Default uses canonical raw cc Dockerfile URL
# QUILT_NIGHTLY_CC_IMAGE=
# Default for --codex uses canonical raw codex Dockerfile URL
# QUILT_NIGHTLY_CODEX_IMAGE=

# Optional in-container command path override
# If unset, quilt-nightly auto-resolves Claude path via /api/containers/:id/exec
# QUILT_NIGHTLY_CLAUDE_PATH=/usr/local/bin/claude
# If unset, quilt-nightly auto-resolves Codex path via /api/containers/:id/exec
# QUILT_NIGHTLY_CODEX_PATH=/usr/local/bin/codex

# Startup wait timeout in milliseconds
QUILT_NIGHTLY_START_TIMEOUT_MS=60000
