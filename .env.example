# Production Quilt API endpoint
QUILT_API_URL=https://backend.quilt.sh

# Required auth for production API
# Set one of these:
QUILT_API_KEY=
# QUILT_TOKEN=
# If both are unset, quilt-nightly prompts: Enter your api key:

# Optional profile image reference overrides
# Default for --cc: ghcr.io/ariacomputecompany/quilt-nightly-cc:latest
# QUILT_NIGHTLY_CC_REF=
# Default for --codex: ghcr.io/ariacomputecompany/quilt-nightly-codex:latest
# QUILT_NIGHTLY_CODEX_REF=

# Optional OCI registry credentials (for private image refs)
# QUILT_NIGHTLY_REGISTRY_USERNAME=
# QUILT_NIGHTLY_REGISTRY_PASSWORD=

# Startup wait timeout in milliseconds
QUILT_NIGHTLY_START_TIMEOUT_MS=60000
